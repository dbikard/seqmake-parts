# https://w3id.org/bioparts  —  Biological Parts Knowledge Base
#
# Permanent, host-independent IRIs for the catalog. This redirect forwards them
# to the live site (currently GitHub Pages); if hosting or the repo name ever
# changes, only this file changes and every published/cited IRI keeps resolving.
#
# Maintained in https://github.com/dbikard/dna-parts-catalog (w3id/bioparts/) and
# submitted as a PR to https://github.com/perma-id/w3id.org

Options +FollowSymLinks
RewriteEngine on

# Local vocabulary terms (cat:) and the namespace document -> the RDF graph.
RewriteRule ^ns https://dbikard.github.io/dna-parts-catalog/catalog.ttl [R=302,L,NE]

# Part and collection IRIs -> their page on the site.
RewriteRule ^part/(.+)$ https://dbikard.github.io/dna-parts-catalog/parts/$1/ [R=302,L,NE]
RewriteRule ^collection/(.+)$ https://dbikard.github.io/dna-parts-catalog/collections/$1/ [R=302,L,NE]

# Machine artifacts.
RewriteRule ^catalog\.(ttl|jsonld|json)$ https://dbikard.github.io/dna-parts-catalog/catalog.$1 [R=302,L,NE]

# The bare base and anything else -> the site root.
RewriteRule ^$ https://dbikard.github.io/dna-parts-catalog/ [R=302,L]
RewriteRule ^(.*)$ https://dbikard.github.io/dna-parts-catalog/$1 [R=302,L]
