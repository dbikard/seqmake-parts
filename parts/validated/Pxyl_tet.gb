     promoter        1..58
                     /label="Pxyl/tet"
                     /synonym="Pxyl/tet"
                     /synonym="Pxyl/tetO"
                     /synonym="ptet_full"
                     /synonym="Tn10 tetA promoter"
                     /note="Pxyl/tet: the TetR-repressible / anhydrotetracycline
                     (aTc)-inducible promoter of the Staphylococcus aureus pRAB
                     expression vectors (Helle et al. 2011). A consensus
                     sigma-70/sigma-A -35 (TTGACA) / -10 (TATAAT) promoter
                     carrying two Tn10 tet operators (the O2/O1 tandem) - one in
                     the -35/-10 spacer and one downstream of the -10 - so bound
                     TetR occludes RNA polymerase until aTc relieves repression.
                     Sequence of record: pRAB11 (GenBank JN635500.1)."
                     /db_xref="SO:0000167"
                     /db_xref="GenBank:JN635500.1"
