FEATURES             Location/Qualifiers
     terminator      1..217
                     /label="rrnBT1T2"
                     /synonym="rrnBT1T2"
                     /synonym="rrnB T1T2"
                     /synonym="rrnB T1-T2 double terminator"
                     /synonym="rrnB T1T2 terminator"
                     /synonym="T1T2"
                     /component="rrnBT1"
                     /component="rrnBT2"
                     /note="rrnB T1+T2 tandem double terminator: the complete
                     T1-T2 intrinsic (Rho-independent) transcription terminator
                     cluster located downstream of the 5S rRNA gene in the E.
                     coli rrnB ribosomal RNA operon. 217 bp taken at 100%
                     identity from the canonical rrnB operon sequence J01695
                     (positions 6362–6578, 1-based; Brosius et al. 1981). bp
                     1–169 are the T1 terminator (catalog part rrnBT1); bp
                     170–217 are the 3' portion of the T2 terminator region
                     (overlapping the 3' end of catalog part rrnBT2). The two
                     terminators function as a tandem unit that strongly and
                     bidirectionally insulates downstream sequence from upstream
                     transcription; both terminate host (E. coli sigma-70) RNA
                     polymerase. Composite of catalog atoms rrnBT1 + rrnBT2;
                     sourced fresh from J01695, not assembled by concatenation."
                     /db_xref="SO:0000141"
                     /citation=[1]
                     /citation=[2]
                     /citation=[4]
                     /citation=[5]
                     /citation=[9]
     terminator      1..169
                     /label="rrnB T1 terminator"
                     /parent="rrnBT1T2"
                     /note="First 169 bp of rrnBT1T2, identical to standalone
                     catalog part rrnBT1. Strong intrinsic (Rho-independent)
                     terminator: a GC-rich hairpin followed by a short U-tract
                     terminates E. coli RNA polymerase. Brosius 1984
                     demonstrated T1 functions as an independent terminator in
                     vivo; Cambray et al. 2013 measured T1 termination
                     efficiency >97% by flow cytometry; Orosz et al. 1991
                     confirmed T1 efficiency in a galK reporter. The element
                     additionally carries a class II conserved sequence
                     (TATCTGTT) that terminates phage (T7/SP6) RNA polymerases
                     independently of the hairpin."
                     /db_xref="SO:0000141"
                     /citation=[1]
                     /citation=[2]
                     /citation=[4]
                     /citation=[9]
     terminator      169..217
                     /label="rrnB T2 terminator"
                     /parent="rrnBT1T2"
                     /note="Last 49 bp of rrnBT1T2, corresponding to the T2
                     terminator core (J01695 ~pos 6528–6576). Brosius 1984
                     showed T2 functions as a standalone terminator in vivo;
                     Orosz et al. 1991 confirmed T2 efficiency and showed
                     inverted T2 has reduced activity, consistent with a
                     hairpin-dependent mechanism. This T2 sub-region is 15 bp
                     shorter at the 5' end than the standalone catalog part
                     rrnBT2 (63 bp), which includes an additional upstream
                     spacer absent from the native T1T2 span."
                     /db_xref="SO:0000141"
                     /citation=[1]
                     /citation=[2]
                     /citation=[4]
     stem_loop       25..47
                     /label="T1 GC-rich hairpin (class I intrinsic terminator
                     stem-loop)"
                     /parent="rrnBT1T2"
                     /note="23-nt GC-rich hairpin (transcript RNA
                     5'-CAGUCGAAAGACUGGGCCUUUCG-3') within rrnB T1, immediately
                     5' of the T1 U-tract. Lyakhov et al. 1997 defined this as
                     the class I (hairpin-dependent) termination signal and
                     showed that disrupting it abolishes class I termination by
                     T7 RNAP; Schwartz, Rahmouni & Boudvillain 2003 used NAIM to
                     map discrete RNA contacts in the lower half of a GC stem
                     during T7 RNAP termination. Note: both cited mechanistic
                     studies use phage T7 RNAP; the hairpin's role for host E.
                     coli RNAP intrinsic termination at this exact stem is
                     inferred from the canonical intrinsic-terminator
                     architecture rather than directly mapped here. Coordinates
                     confirmed by exact sequence match at 24–47."
                     /db_xref="SO:0000313"
                     /citation=[1]
                     /citation=[6]
                     /citation=[7]
     misc_feature    48..51
                     /label="poly-U tract (rrnB T1)"
                     /parent="rrnBT1T2"
                     /note="Four-uridine (UUUU) run in the transcript
                     immediately 3' of the T1 hairpin that destabilizes the
                     RNA:DNA hybrid to release the polymerase. Unusually short
                     (4 nt vs the 6–8 nt consensus); Schmidt & Chamberlin 1987
                     showed NusA enhances rrnB T1 termination in vitro to
                     in-vivo-equivalent levels, consistent with the short U-run
                     being partly rate-limiting in isolation. TTTT confirmed at
                     47–51 (0-based, half-open)."
                     /db_xref="SO:0000110"
                     /citation=[1]
                     /citation=[3]
     misc_feature    51..58
                     /label="class II conserved sequence (TATCTGTT) — phage RNAP
                     termination signal"
                     /parent="rrnBT1T2"
                     /note="8-bp conserved sequence (CS) TATCTGTT, the class II
                     termination signal of rrnB T1 that acts independently of
                     the upstream hairpin and is relevant only for phage RNA
                     polymerases (T7, SP6). Lyakhov et al. 1997 showed T7 RNAP
                     mutants that fail at the class I hairpin still terminate at
                     this CS; Sohn & Kang 2004 characterized the mechanism
                     (sequential conformational changes in T7 RNAP, no hairpin
                     required). Not required for E. coli RNAP intrinsic
                     termination. TATCTGTT confirmed at 50–58."
                     /db_xref="SO:0000110"
                     /citation=[6]
                     /citation=[8]
     stem_loop       187..210
                     /label="T2 GC-rich hairpin (intrinsic terminator
                     stem-loop)"
                     /parent="rrnBT1T2"
                     /note="24-nt hairpin within rrnB T2 comprising a perfect
                     10-bp palindromic stem (5'-AAGGCCATCC / GGATGGCCTT-3',
                     reverse-complement confirmed) and a 4-nt loop (TGAC).
                     Brosius et al. 1981 sequenced the region; Lyakhov et al.
                     1997 showed T7 RNAP terminates normally at rrnB T2
                     (consistent with a functional hairpin); Orosz et al. 1991
                     showed directional reduction of T2 activity in inverted
                     orientation, consistent with hairpin dependence.
                     Coordinates rest on computational palindrome
                     identification, not direct experimental mapping —
                     provisional extent."
                     /db_xref="SO:0000313"
                     /citation=[1]
                     /citation=[4]
                     /citation=[6]
     misc_feature    209..213
                     /label="poly-U tract (rrnB T2)"
                     /parent="rrnBT1T2"
                     /note="5-nt contiguous T-run (transcript UUUUU) at the 3'
                     end of the T2 hairpin; pos 208–209 are also the terminal 2
                     nt of the 3' stem arm, so the pure post-stem U-run is 3 nt
                     (pos 210–212). Intrinsic terminators require a U-tract
                     immediately 3' of the hairpin for RNA:DNA hybrid melting
                     and transcript release (Cambray et al. 2013). T2's U-tract
                     is longer than T1's (4 nt), consistent with T2 terminating
                     efficiently without NusA enhancement. Coordinates confirmed
                     by sequence analysis of rrnBT1T2 / J01695; extent rests on
                     computational identification — provisional."
                     /db_xref="SO:0000110"
                     /citation=[1]
                     /citation=[9]
