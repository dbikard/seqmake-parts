                     /parent="Gateway_attP1"
                     /note="Common-core crossover region carrying the
                     specificity-1 7 bp overlap (GTACAAAA...); strand exchange
                     by lambda Int occurs across this overlap, and its sequence
                     makes attP1 recombine only with the cognate attB1."
                     /db_xref="SO:0000057"
