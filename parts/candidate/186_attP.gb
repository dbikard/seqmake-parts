FEATURES             Location/Qualifiers
     protein_bind    1..307
                     /label="186_attP"
                     /synonym="186_attP"
                     /synonym="186 attP"
                     /synonym="phage 186 attP"
                     /synonym="186 attachment site"
                     /note="Bacteriophage 186 phage attachment site (attP) for
                     the 186 tyrosine integrase. 307 bp spanning the full attP
                     functional region: Int arm-type recognition sequences on
                     the P (left) and P' (right) arms, a single P-arm IHF site,
                     the tRNA-Ile/attB common core (BOB') with the predicted
                     7-bp staggered crossover, a right-arm IHF site, and five
                     Apl (recombination directionality factor) operators. 186 is
                     a P2-family lambdoid coliphage; integration into the host
                     chromosome (within the ileY tRNA-Ile locus) requires 186
                     Int + IHF, while Apl directs excision. Source: NC_001317.1
                     positions 20867-21173."
                     /db_xref="SO:0000057"
                     /citation=[1]
                     /citation=[2]
                     /citation=[6]
                     /collection="phage-att-sites"
     protein_bind    complement(13..23)
                     /label="Int arm-type site 1 (P arm)"
                     /parent="186_attP"
                     /note="Predicted Int arm-type recognition sequence. The arm
                     motif (consensus YAYCGCCAYTY) lies on the minus strand
                     here: reverse complement of the [12,23) forward sequence
                     (AAGTGGCGGTA) is TACCGCCACTT, matching the consensus.
                     GenBank NC_001317.1 annotates a protein_bind region (genome
                     20889-21147) /bound_moiety=Int /note='predicted Int
                     arm-type recognition sequences; 3 sites to left of attP'. P
                     arm site 1 of 3. Extent rests on GenBank prediction + the
                     arm-site consensus, not on 186-specific footprinting; P2 (a
                     relative) uses a distinct arm consensus (TGTGGACA), so the
                     186 motif assignment is provisional."
                     /db_xref="SO:0000057"
                     /citation=[1]
                     /citation=[3]
