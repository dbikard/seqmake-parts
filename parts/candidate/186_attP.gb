     protein_bind    93..119
                     /label="IHF site H1 (P arm)"
                     /parent="186_attP"
                     /note="Integration host factor (IHF) binding site on the P
                     (left) arm, between the core and the P-arm Int sites (27
                     bp). GenBank NC_001317.1 annotates protein_bind here with
                     /bound_moiety=IHF and an /experiment qualifier. P2-family
                     attPs carry a single P-arm IHF site (in contrast to
                     lambda). Provisional: the position derives from the GenBank
                     annotation and the P2-family architecture; no 186-specific
                     IHF footprinting paper was located."
                     /db_xref="SO:0000057"
                     /citation=[3]
                     /citation=[5]
     misc_feature    119..164
                     /label="tRNA-Ile / attB common core (BOB')"
                     /parent="186_attP"
                     /note="BOB' core region shared between phage attP and the
                     host attB, overlapping a (truncated) tRNA-Ile gene;
                     integration occurs within the E. coli ileY tRNA-Ile locus.
                     GenBank NC_001317.1 annotates a tRNA feature
                     (/note='truncated') across this span, with an interior
                     sub-region shared with attB. Provisional: extent taken from
                     the GenBank annotation; no 186-specific paper delimiting
                     the attB-common core was located."
                     /db_xref="SO:0000057"
                     /citation=[2]
                     /citation=[6]
