      "@id": "part:ALFA_tag_claim_light_control",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "sequence_variant",
      "cat:claimValue": "{\"Kd_activated\": \"~183\\u2013346 pM\", \"Kd_dark\": \"3.2\\u20137.9 \\u00b5M\", \"activation_wavelength\": \"365 nm UV\", \"variant\": \"NbALFA Tyr42ONBY (ALFA-Pb)\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "photocaged variant with Tyr42ONBY has Kd 3.2\u20137.9 \u00b5M inactive, restores to ~183\u2013346 pM after 365 nm UV irradiation",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results",
      "dcterms:references": {
