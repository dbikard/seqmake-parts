    {
      "@id": "part:SNAP_tag_claim_sequence_feature",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "domain_function",
      "cat:claimValue": "{\"active_site_residue\": \"active-site cysteine\", \"canonical_position\": \"Cys145 (hAGT numbering)\", \"inactivating_mutation\": \"C145A abolishes catalytic alkyl-transfer activity\", \"motif\": \"I-P-C-H-R active-site motif\", \"position_in_stored_sequence\": 144}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The methyl group is transferred to a cysteine acceptor residue in the AGT protein, which is located at residue 145. The C145A mutant of AGT in which this cysteine is converted to an alanine residue is therefore inactive.",
