      },
      "prov:wasGeneratedBy": {
        "@id": "part:CBP_tag_claim_affinity_matrix_provenance"
      },
      "rdfs:label": "Purified on immobilized calmodulin (calmodulin-agarose) and eluted with EGTA"
    },
    {
      "@id": "part:CBP_tag_claim_affinity_matrix_provenance",
      "@type": "prov:Activity",
