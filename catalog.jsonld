      },
      "prov:wasGeneratedBy": {
        "@id": "part:SpyTag003_claim_application_provenance"
      },
      "rdfs:label": "Rapid covalent module for protein assembly, detection, anchoring, vaccines and split-protein reconstitution"
    },
    {
      "@id": "part:SpyTag003_claim_application_provenance",
