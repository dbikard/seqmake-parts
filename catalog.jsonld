    },
    {
      "@id": "part:SnoopTag_claim_performance_yield",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "flagged",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"note\": \"Reported reaction completeness for the SnoopTag/SnoopCatcher pair.\", \"readout\": \"isopeptide bond formation between SnoopTag and SnoopCatcher\", \"yield\": \">99%\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "SnoopTag, which formed a spontaneous isopeptide bond to its protein partner SnoopCatcher with >99% yield and no cross-reaction to SpyTag/SpyCatcher",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Reaction efficiency and completeness are operationally critical: a designer selecting SnoopTag/SnoopCatcher needs to know if the reaction will go to completion with their intended stoichiometry and conditions. This determines whether they can use the system reliably in polyprotein assembly.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:26787909"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:26787909"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:SnoopTag_claim_performance_yield_provenance"
      },
      "rdfs:comment": "superseded by performance_yield__v2: The abstract states '>99% yield' but experimental data shows this is conditional on stoichiometry: 1:1 ratio gives only ~80%, while excess partner drives near-complete reaction. The exact percentage for 'quantitative' conversion is not numerically specified beyond 'almost quantitative' in discussion.\"",
      "rdfs:label": "SnoopTag + SnoopCatcher react to >99% yield"
    },
    {
      "@id": "part:SnoopTag_claim_performance_yield__v2",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"note\": \"Reaction completeness is stoichiometry-dependent: ~80% at 1:1 molar ratio; quantitative (~95%+) conversion when either partner is in twofold excess. Quantitatively reacted SnoopCatcher was ~100% consumed with excess SnoopTag-MBP.\", \"readout\": \"isopeptide bond formation between SnoopTag and SnoopCatcher\", \"yield\": \"~100% (1:1 ratio ~80%; quantitative with excess partner)\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "With a 1:1 SnoopCatcher to SnoopTag-MBP, \u223c80% of SnoopTag-MBP reacted. However, with a twofold excess of SnoopCatcher, SnoopTag-MBP reacted quantitatively (Fig. 1E and Fig. S1B). Similarly with an excess of SnoopTag-MBP, SnoopCatcher was \u223c100% consumed (Fig. 1F and Fig. S1C).",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "cat:supersedes": {
        "@id": "part:SnoopTag_claim_performance_yield"
      },
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Reaction efficiency and completeness are operationally critical: a designer selecting SnoopTag/SnoopCatcher needs to know if the reaction will go to completion with their intended stoichiometry and conditions. This determines whether they can use the system reliably in polyprotein assembly.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:26787909"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:26787909"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:SnoopTag_claim_performance_yield__v2_provenance"
      },
      "rdfs:label": "SnoopTag + SnoopCatcher react quantitatively to completion with excess partner (stoichiometry-dependent)"
    },
    {
      "@id": "part:SnoopTag_claim_performance_yield__v2_provenance",
