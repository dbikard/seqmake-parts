    {
      "@id": "part:phiC31_attP",
      "@type": "sbol:Component",
      "cat:curationStatus": "candidate",
      "cat:documented": false,
      "cat:hasFunctionalClaim": [
        {
          "@id": "part:phiC31_attP_claim_mechanism"
        },
