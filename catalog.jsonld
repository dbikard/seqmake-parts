  "@graph": [
    {
      "@id": "collection:affinity-tags",
      "@type": "sbol:Collection",
      "dcterms:description": "Peptide and protein tags that give a recombinant protein a defined, reversible binding handle for single-step affinity capture. The set spans the small metal-chelation peptide 6xHis (IMAC), the streptavidin/Strep-Tactin\u2013binding Strep-tag II and Twin-Strep-tag, the FLAG octapeptide (anti-FLAG resin), the S-protein\u2013binding S-tag, the calmodulin-binding peptide (CBP) and streptavidin-binding peptide (SBP) used in tandem-affinity workflows, and the larger fusion-protein handles GST (glutathione resin) and MBP (amylose resin), which double as solubility partners. Each is captured on an immobilised cognate ligand and released under mild, tag-specific conditions (imidazole, desthiobiotin/biotin, competing peptide, glutathione, maltose, or EGTA).",
      "dcterms:title": "Affinity purification tags",
      "sbol:displayId": "affinity-tags",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
