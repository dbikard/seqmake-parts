    {
      "@id": "part:CBP_tag_claim_affinity_matrix",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "affinity_matrix",
      "cat:claimValue": "{\"binding_condition\": \"Ca2+ present\", \"elution\": \"EGTA (~2 mM)\", \"matrix\": \"calmodulin-agarose / calmodulin resin\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Because the binding between CBP and calmodulin is calcium-dependent, the fusion protein can be eluted from the resin with virtually any buffer containing EGTA (2 mM) and used directly for many applications.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9047344"
      },
      "prov:wasDerivedFrom": {
