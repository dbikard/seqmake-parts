    },
    {
      "@id": "part:CBP_tag_claim_host_range",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "host_range",
      "cat:claimValue": "{\"hosts\": [\"Escherichia coli\", \"Saccharomyces cerevisiae / eukaryotic cells (TAP)\"], \"note\": \"E. coli use supported by abstract; eukaryotic/TAP use inferred from the TAP method (CBP is the second TAP handle), a detail residing in the Rigaut 1999 full text.\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Proteins fused in frame with CBP can be purified from crude E. coli lysates in a single step using calmodulin affinity chromatography",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9047344"
