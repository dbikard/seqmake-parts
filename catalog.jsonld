    {
      "@id": "part:rrnBT1_claim_mechanism",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"class\": \"class I (hairpin-dependent)\", \"hairpin\": \"CAGTCGAAAGACTGGGCCTTTCG\", \"mechanism\": \"intrinsic\", \"rho_dependent\": false, \"u_tract\": \"TTTT\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "two signals in rrnB T1: a class I (hairpin-dependent) signal and a class II conserved-sequence signal",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9192998"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:9192998"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:rrnBT1_claim_mechanism_provenance"
      },
      "rdfs:label": "Intrinsic (Rho-independent) transcription terminator: a GC-rich hairpin followed by a short U-tract releases E. coli RNA polymerase without accessory factors."
    },
    {
      "@id": "part:rrnBT1_claim_mechanism_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-workflow",
