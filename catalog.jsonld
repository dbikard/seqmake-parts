      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"effect\": \"enhances termination\", \"factor\": \"NusA\", \"u_tract_length\": 4}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:sourceQuote": "NusA protein is an efficient transcription termination factor for certain terminator sites, enhancing rrnB T1 termination",
      "cat:sourceQuoteFrom": "primary",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:2821282"
