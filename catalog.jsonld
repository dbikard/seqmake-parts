    {
      "@id": "part:SpyTag003_claim_affinity_matrix",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "affinity_matrix",
      "cat:claimValue": "{\"basis\": \"exploits the strong noncovalent SpyTag003:SpyDock interaction\", \"elution_note\": \"SpyTag003 binds SpyDock more tightly than earlier generations and reportedly needs harsher elution; the precise elution condition is described in the dedicated Spy&Go report (PMID 30988307) which was only available at abstract level\", \"matrix\": \"immobilised non-reactive SpyCatcher variant (SpyDock / pseudo-SpyCatcher)\", \"purity_pct\": 92}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "We took advantage of the strong noncovalent interaction between SpyTag003 and a nonreactive SpyCatcher variant (SpyDock) for affinity purification using the Spy&Go system. This enabled purification of SpyTag003 fusions from cell lysate with 92% purity.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results - Analysis of the SpyTag003/SpyCatcher003 System",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:SpyTag003_claim_affinity_matrix_provenance"
      },
      "rdfs:label": "Spy&Go (immobilised non-reactive SpyDock) affinity purification of SpyTag003 fusions"
    },
    {
      "@id": "part:SpyTag003_claim_affinity_matrix_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
