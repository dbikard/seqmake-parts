    {
      "@id": "part:CBP_tag_claim_sequence_variant",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "sequence_variant",
      "cat:claimValue": "{\"Kd_pM\": 2, \"cofactor_required\": \"Ca2+\", \"maps_to_part_positions\": \"2-21 with an N->A substitution\", \"reversal\": \"EDTA\", \"variant\": \"N5A\", \"variant_sequence\": \"RWKKNFIAVSAANRFKKIS\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The immobilization relies on the ultra high affinity of calmodulin to N5A mutant CBP (RWKKNFIAVSAANRFKKIS) in presence of calcium (KD~2 pM), which can be reversed by EDTA",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
