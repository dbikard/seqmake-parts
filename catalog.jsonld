    {
      "@id": "part:CBP_tag_claim_ligand",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "ligand",
      "cat:claimValue": "{\"cofactor_required\": \"Ca2+\", \"ligand\": \"calmodulin\", \"stoichiometry\": \"1:1\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "fluorescence enhancement is maximal at a peptide:calmodulin stoichiometry of 1:1. Calmodulin-Sepharose affinity chromatography in the presence of 2 M urea indicates that the interaction of peptide and calmodulin is Ca2+-dependent.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:3858814"
