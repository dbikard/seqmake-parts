        }
      ],
      "cat:slug": "AviTag",
      "dcterms:description": "15-aa synthetic biotin acceptor peptide (GLNDIFEAQKIEWHE) optimized from a 13-residue BirA consensus identified by Schatz 1993 (PMID:7764094). Beckett et al. 1999 (PMID:10211839) defined the minimal 14-mer and confirmed the optimized 15-mer achieves kcat/Km comparable to the natural BCCP substrate; Lys11 (K10 in original Schatz numbering) is the biotinylation site. Biotinylation is catalyzed by Escherichia coli biotin ligase BirA.",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:7764094"
        },
        {
          "@id": "https://identifiers.org/pubmed:10211839"
        },
        {
          "@id": "https://identifiers.org/pubmed:9750126"
        },
        {
          "@id": "https://identifiers.org/pubmed:15897449"
        },
        {
