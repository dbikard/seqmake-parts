    {
      "@id": "collection:gateway-att-sites",
      "@type": "sbol:Collection",
      "dcterms:description": "The att recombination sites of the Gateway cloning system: engineered derivatives of the bacteriophage lambda att/Int system in which the central 7 bp overlap was altered to create two mutually orthogonal specificities (1 and 2). attB x attP (the BP reaction, lambda Int + IHF) gives attL + attR, and attL x attR (LR) regenerates attB + attP; using distinct specificities at the two ends of a fragment makes the reactions directional. attP1/attP2 are the ~232 bp donor-vector (pDONR) sites; attB1/attB2 are the 25 bp minimal sites added to a fragment by PCR primer tails. Each attP is cross-linked to its cognate attB.",
      "dcterms:title": "Gateway (lambda-derived) recombinational-cloning att sites",
      "sbol:displayId": "gateway-att-sites",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
      "sbol:member": [
        {
          "@id": "part:Gateway_attB1"
        },
        {
          "@id": "part:Gateway_attB2"
        },
        {
          "@id": "part:Gateway_attP1"
        },
        {
          "@id": "part:Gateway_attP2"
        }
      ]
    },
    {
      "@id": "collection:phage-att-sites",
      "@type": "sbol:Collection",
      "dcterms:description": "Phage-borne attP attachment sites from phylogenetically distinct, mutually orthogonal site-specific recombination systems, each recognized by its own dedicated integrase and not cross-reacting with the others: phiC31 attP (Streptomyces phage phiC31; a large serine integrase that needs no host factors and gives highly directional integration), and the tyrosine-integrase attP sites of coliphages lambda, 186 (a P2-family system that also uses the Apl directionality factor), phi80, and HK022 (which use the host integration host factor IHF, and an excisionase for the reverse reaction). Each attP is the phage half of an attP x attB recombination pair; the cognate bacterial attB sites (in the host chromosome, or a pseudo-attB in non-native hosts for phiC31) are being added. These orthogonal sites are widely used as landing pads for stable, single-copy genomic integration.",
      "dcterms:title": "Phage attachment sites for chromosomal integration",
      "sbol:displayId": "phage-att-sites",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
      "sbol:member": [
        {
          "@id": "part:186_attB"
        },
        {
          "@id": "part:186_attP"
        },
        {
          "@id": "part:HK022_attB"
        },
        {
          "@id": "part:HK022_attP"
        },
        {
          "@id": "part:lambda_attB"
        },
        {
          "@id": "part:lambda_attP"
        },
        {
          "@id": "part:phi80_attB"
        },
        {
          "@id": "part:phi80_attP"
        },
        {
          "@id": "part:phiC31_attB"
        },
        {
          "@id": "part:phiC31_attP"
        }
      ]
    },
    {
      "@id": "collection:protease-cleavage-sites",
      "@type": "sbol:Collection",
      "dcterms:description": "Short recognition sequences engineered into the linker between an affinity/solubility tag and the protein of interest so the tag can be removed by a sequence-specific protease after purification, plus the SUMO-specific protease Ulp1. The cleavage sites include TEV (ENLYFQG), HRV 3C/PreScission (LEVLFQGP), thrombin (LVPRGS), enterokinase (DDDDK) and Factor Xa (IEGR); they differ in specificity, the residual N-terminal scar, and off-target propensity. Ulp1 instead recognises the folded SUMO domain rather than a linear motif and cleaves scarlessly.",
      "dcterms:title": "Protease cleavage sites for tag removal",
      "sbol:displayId": "protease-cleavage-sites",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
      "sbol:member": [
        {
          "@id": "part:FactorXa_site"
        },
        {
          "@id": "part:HRV3C_site"
        },
        {
          "@id": "part:TEV_site"
        },
        {
          "@id": "part:Ulp1"
        },
        {
          "@id": "part:enterokinase_site"
        },
        {
          "@id": "part:thrombin_site"
        }
      ]
    },
    {
      "@id": "collection:solubility-tags",
      "@type": "sbol:Collection",
      "dcterms:description": "Larger protein fusion partners that promote the soluble, correctly folded expression of an otherwise aggregation-prone passenger, typically as an N-terminal fusion later removed by a site-specific protease. The set comprises the E. coli proteins MBP (maltose-binding protein), thioredoxin (Trx), and NusA, the Schistosoma GST, and the ubiquitin-like SUMO (yeast Smt3), whose cognate protease Ulp1 cleaves at the folded SUMO domain to release a native N-terminus. Several of these (MBP, GST) are also affinity handles.",
      "dcterms:title": "Solubility-enhancing fusion partners",
      "sbol:displayId": "solubility-tags",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
      "sbol:member": [
