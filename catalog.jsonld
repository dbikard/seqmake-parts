      },
      "prov:wasGeneratedBy": {
        "@id": "part:CBP_tag_claim_expression_yield_provenance"
      },
      "rdfs:label": "Supports high-level fusion-protein expression in E. coli (15-20 mg/L for a CBP-JNK fusion)"
    },
    {
      "@id": "part:CBP_tag_claim_expression_yield_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "primary",
