      "cat:analysisStatus": "pending",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"Kd_nM\": 73, \"Kd_uM\": 0.073, \"SpyTag_Kd_uM\": 0.75, \"fold_tighter_than_SpyTag\": 10, \"method\": \"isothermal titration calorimetry (ITC)\", \"partner\": \"SpyDock (SpyCatcher2.1 S49C E77A, a non-reactive SpyCatcher variant)\", \"stoichiometry\": \"1:1\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "we used isothermal titration calorimetry (ITC) to measure the dissociation constant for SpyDock's interaction with SpyTag-MBP or SpyTag002-MBP. Both proteins bound with 1:1 stoichiometry. SpyTag002-MBP (Kd = 0.073 \u03bcM) bound ~10-fold tighter than SpyTag-MBP (Kd = 0.75 \u03bcM)",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results (SpyDock binding)",
      "dcterms:references": {
