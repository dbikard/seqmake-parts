    {
      "@id": "part:AviTag_claim_binding_affinity",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "flagged",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"Kd_streptavidin\": \"~10^-15 M (femtomolar)\", \"ligand\": \"streptavidin (tetrameric or monovalent)\", \"note\": \"Affinity is for biotin-streptavidin interaction; AviTag provides the site-specific biotin handle\", \"preferred_partner\": \"monovalent streptavidin (mSA) to prevent receptor crosslinking in live-cell applications\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "A monovalent streptavidin with a single femtomolar biotin binding site",
      "cat:sourceQuoteFrom": "catalog-doc",
      "cat:sourceSection": "Title",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Discriminates AviTag via femtomolar biotin-streptavidin affinity; specifies actionable monovalent streptavidin partner to prevent receptor crosslinking in live-cell applications; quantitative and risk-reducing (addresses failure mode)",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:16554831"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:16554831"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_binding_affinity_provenance"
      },
      "rdfs:comment": "superseded by binding_affinity__v2: Measured Kd is 4.8 \u00d7 10\u207b\u00b9\u2074 M, not the claimed ~10\u207b\u00b9\u2075 M; both are femtomolar but claim overstates affinity by ~10-fold",
      "rdfs:label": "Biotinylated AviTag binds streptavidin with femtomolar affinity (Kd ~10^-15 M); monovalent streptavidin (mSA) is the preferred detection partner to avoid receptor crosslinking."
    },
    {
      "@id": "part:AviTag_claim_binding_affinity__v2",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"Kd_streptavidin\": \"~4.8 \\u00d7 10^-14 M (femtomolar)\", \"ligand\": \"streptavidin (tetrameric or monovalent)\", \"note\": \"Affinity is for biotin-streptavidin interaction; AviTag provides the site-specific biotin handle\", \"preferred_partner\": \"monovalent streptavidin (mSA) to prevent receptor crosslinking in live-cell applications\"}",
      "cat:confidence": "high",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "The investigators measured a dissociation constant (Kd) of 4.8 \u00d7 10\u207b\u00b9\u2074 \u00b1 0.5 \u00d7 10\u207b\u00b9\u2074 M for their monovalent variant, comparable to wild-type streptavidin's 4.0 \u00d7 10\u207b\u00b9\u2074 M",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title",
      "cat:supersedes": {
        "@id": "part:AviTag_claim_binding_affinity"
      },
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Discriminates AviTag via femtomolar biotin-streptavidin affinity; specifies actionable monovalent streptavidin partner to prevent receptor crosslinking in live-cell applications; quantitative and risk-reducing (addresses failure mode)",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:16554831"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:16554831"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_binding_affinity__v2_provenance"
      },
      "rdfs:label": "Biotinylated AviTag binds streptavidin with femtomolar affinity (Kd ~10^-15 M); monovalent streptavidin (mSA) is the preferred detection partner to avoid receptor crosslinking."
    },
    {
      "@id": "part:AviTag_claim_binding_affinity__v2_provenance",
      "@type": "prov:Activity",
