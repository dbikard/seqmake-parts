    {
      "@id": "part:SnoopTag_claim_sequence_variant",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "flagged",
      "cat:claimType": "sequence_variant",
      "cat:claimValue": "{\"note\": \"All derived from the same S. pneumoniae RrgA scaffold; these are distinct related parts, not this exact peptide.\", \"variants\": [\"SnoopTagJr (three-part RrgA split with DogTag + SnoopLigase)\", \"DogTag (loop-insertable, paired with DogCatcher)\", \"SnoopTag2 (second-generation, accelerated ligation)\"]}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "Three-part RrgA split generating SnoopTagJr, DogTag, and SnoopLigase",
      "cat:sourceQuoteFrom": "catalog-doc",
      "cat:sourceSection": "candidate-reference summary",
      "cat:usefulness": "medium",
      "cat:usefulnessRationale": "The claim identifies related RrgA-derived variants useful for understanding the SnoopTag ecosystem and evolutionary development, but includes unverified SnoopTag2 which is not supported by the cited 2018 paper.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:29402082"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:29402082"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:SnoopTag_claim_sequence_variant_provenance"
      },
      "rdfs:comment": "superseded by sequence_variant__v2: SnoopTag2 is not mentioned in the cited 2018 Buldun et al. paper; SnoopTag2 likely derives from a different publication not cited here.",
      "rdfs:label": "RrgA scaffold is evolvable: SnoopTagJr, DogTag, SnoopTag2 derivatives"
    },
    {
      "@id": "part:SnoopTag_claim_sequence_variant__v2",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "flagged",
      "cat:claimType": "sequence_variant",
      "cat:claimValue": "{\"note\": \"All derived from three-part splitting of S. pneumoniae RrgA C-terminal domain (Buldun et al. 2018 JACS). SnoopTag2 is not described in this reference.\", \"variants\": [\"SnoopTagJr (improved SnoopTag with D737S, 12 amino acids, residues 734-745)\", \"DogTag (loop-insertable, 23 amino acids, residues 838-860)\", \"SnoopLigase (catalytic ligase, residues 743-846 with A808P Q837P D838G I839V mutations)\"]}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "We initially developed these components by three-part splitting of the Streptococcus pneumoniae adhesin RrgA. The units were then engineered, guided by structure, bioinformatic analysis of sequence homology, and computational prediction of stability.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "candidate-reference summary",
      "cat:supersedes": {
        "@id": "part:SnoopTag_claim_sequence_variant"
      },
      "cat:usefulness": "medium",
      "cat:usefulnessRationale": "The claim identifies related RrgA-derived variants useful for understanding the SnoopTag ecosystem and evolutionary development, but includes unverified SnoopTag2 which is not supported by the cited 2018 paper.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:29402082"
