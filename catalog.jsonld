      },
      "prov:wasGeneratedBy": {
        "@id": "part:6xHis_claim_mechanism_provenance"
      },
      "rdfs:label": "Adjacent histidine residues chelate immobilized divalent transition-metal ions (Ni2+, Co2+, Cu2+, Zn2+) on an IMAC matrix, enabling single-step affinity purification; protein is eluted by imidazole competition or low pH."
    },
