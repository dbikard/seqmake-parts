          "@id": "part:SnoopCatcher_claim_host_range"
        }
      ],
      "cat:slug": "SnoopCatcher",
      "dcterms:description": "Protein partner (~112 aa) split from the D4 (CnaA-like) domain of Streptococcus pneumoniae RrgA pilus adhesin (residues 749-860). On mixing with the peptide SnoopTag it reconstitutes the split domain and forms a spontaneous, covalent intermolecular isopeptide bond (its reactive Asn854 to the reactive Lys742 of SnoopTag), irreversibly locking the two units together. Orthogonal to the SpyTag/SpyCatcher pair. Canonical Veggiani 2016 engineered form (G842T + D848G stabilizing mutations), deposit AMD39965.1.",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:26787909"
        },
        {
          "@id": "https://identifiers.org/pubmed:29402082"
        },
        {
          "@id": "https://identifiers.org/pubmed:34324879"
        },
        {
          "@id": "https://identifiers.org/pubmed:30028591"
        },
        {
          "@id": "https://identifiers.org/pubmed:37289810"
        }
      ],
      "dcterms:title": "SnoopCatcher",
      "rdfs:label": "SnoopCatcher",
      "sbol:displayId": "SnoopCatcher",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
      "sbol:hasSequence": {
        "@id": "part:SnoopCatcher_sequence"
      },
      "sbol:role": {
        "@id": "https://identifiers.org/SO:0000417"
      },
      "sbol:type": {
        "@id": "https://identifiers.org/SBO:0000252"
      },
      "skos:altLabel": "Snoop Catcher"
    },
    {
      "@id": "part:SnoopCatcher_claim_application",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "application",
      "cat:claimValue": "{\"applications\": [\"covalent capture of a SnoopTagged protein module\", \"sequential / programmable polyprotein ('polyproteam') assembly when combined orthogonally with SpyTag/SpyCatcher\", \"modular plug-and-display of antigens on multivalent nanoparticle/VLP scaffolds\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Solid-phase attachment followed by sequential SpyTag or SnoopTag reaction between building-blocks enabled iterative extension. Linear, branched, and combinatorial polyproteins were synthesized",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:26787909"
