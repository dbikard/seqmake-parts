    {
      "@id": "part:SpyTag003_claim_binding_affinity",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"covalent\": true, \"kinetic_Kd_estimates_nM\": [3, 13], \"method\": \"surface plasmon resonance on non-reactive SpyTag003 DA (D-to-A) variant; isotherm too tight to measure by ITC\", \"noncovalent_Kd_error_nM\": 4, \"noncovalent_Kd_nM_SPR\": 21, \"note\": \"the reactive SpyTag003/SpyCatcher003 pair forms a covalent bond (no equilibrium dissociation); 21 nM is the noncovalent docking affinity of the reaction-dead DA variant\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "SpyTag003 DA:SpyCatcher003 still represents a high-affinity interaction: its affinity was too strong to measure by ITC, so we used surface plasmon resonance (SPR) to obtain a Kd = 21 +/- 4 nM",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results - Intracellular Coupling of Split Talin Fragments",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:31822621"
