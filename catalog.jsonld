      "cat:claimType": "placement",
      "cat:claimValue": "{\"note\": \"N-terminal CBP (pCAL-type) ensures efficient translation; CBP is the C-terminal handle in TAP.\", \"positions\": [\"N-terminal\", \"C-terminal\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The CBP coding sequence was positioned for fusion at the N-terminus, an advantage that ensures consistent high level synthesis of fusion proteins due to the efficient translation of the CBP in E. coli.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9047344"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:9047344"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:CBP_tag_claim_placement_provenance"
      },
      "rdfs:label": "Used at either terminus; N-terminal placement gives efficient translation initiation and high yield"
    },
    {
      "@id": "part:CBP_tag_claim_placement_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "primary",
