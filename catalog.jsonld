      ]
    },
    {
      "@id": "part:AviTag_claim_application",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "application",
      "cat:claimValue": "{\"applications\": [\"streptavidin/avidin affinity purification (one-step capture after in vivo or in vitro biotinylation)\", \"live-cell surface protein labeling with streptavidin or monovalent streptavidin probes\", \"single-molecule imaging and quantum dot targeting\", \"chromatin immunoprecipitation (ChIP) of biotinylated nuclear proteins\", \"protein immobilization on streptavidin-coated surfaces\"]}",
      "cat:confidence": "medium",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "We show that mammalian cell surface proteins tagged with AP can be biotinylated by biotin ligase added to the medium ... The biotin group then serves as a handle for targeting streptavidin-conjugated quantum dots (QDs). ... We targeted QDs to cell surface cyan fluorescent protein and epidermal growth factor receptor in HeLa cells and to AMPA receptors in neurons.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "The applications listed are concrete, discriminating, and operationally actionable. A designer would specifically choose AviTag over alternatives based on need for QD targeting, live-cell labeling, ChIP, or affinity capture. Each application addresses a distinct use case.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:15897449"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:15897449"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_application_provenance"
      },
      "rdfs:label": "AviTag enables site-specific single-biotin installation for streptavidin-based detection, affinity capture, live-cell surface protein labeling, and ChIP."
    },
    {
      "@id": "part:AviTag_claim_application_provenance",
