    {
      "@id": "part:186_attP_claim_directionality_factor",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "regulation",
      "cat:claimValue": "{\"binding\": \"multiple cooperative direct-repeat operators spaced ~one helical turn apart\", \"effect\": \"promotes excision, inhibits integration\", \"factor\": \"Apl\", \"role\": \"recombination directionality factor (excisionase)\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The Apl protein of bacteriophage 186 functions both as an excisionase and as a transcriptional regulator; binding to the phage attachment site (att) ... Apl binding sites are direct repeats spaced one DNA helix turn apart ... Apl binds to multiple sites with high cooperativity, bends the DNA and spreads from specific binding sites into adjacent non-specific DNA",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:32789491"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:32789491"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:186_attP_claim_directionality_factor_provenance"
      },
      "rdfs:label": "Apl, the 186 recombination directionality factor, binds multiple cooperative direct-repeat operators within attP, bends the DNA, and directs excision while inhibiting integration."
    },
    {
      "@id": "part:186_attP_claim_directionality_factor_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-workflow",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:186_attP_claim_host_integration_locus",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "host_range",
      "cat:claimValue": "{\"attB_locus\": \"tRNA-Ile (ileY)\", \"core\": \"BOB' common core shared between attP and attB\", \"host\": \"Escherichia coli\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The PstI fragment ... of coliphage 186, known genetically to encode the major control genes ... seven genes, including the int and cI genes",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:3806670"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:3806670"
      },
      "prov:wasGeneratedBy": {
