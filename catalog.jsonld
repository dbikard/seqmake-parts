    {
      "@id": "part:HK022_attP_claim_host_range",
      "@type": "cat:FunctionalClaim",
      "cat:claimType": "host_range",
      "cat:claimValue": "{\"chromosomal_locus\": \"leuX (tRNA-Leu) for the bacterial attB\", \"host\": \"Escherichia coli\", \"requires\": \"HK022 Int (plus IHF; Xis for excision)\"}",
      "cat:confidence": "high",
      "cat:reviewStatus": "ai-generated",
      "cat:sourceQuote": "CRIM plasmids are integrated into the chromosome by site-specific recombination at one of five different phage attachment sites.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:11591683"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:11591683"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:HK022_attP_claim_host_range_provenance"
      },
      "rdfs:label": "Functions as a site-specific chromosomal integration landing pad in Escherichia coli (and related enterobacteria) when paired with HK022 Int; the cognate bacterial attB lies in the leuX tRNA-Leu gene."
    },
    {
      "@id": "part:HK022_attP_claim_host_range_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-workflow",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:HK022_attP_claim_mechanism",
      "@type": "cat:FunctionalClaim",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"accessory_factors\": [\"IHF\", \"Xis (excision/directionality)\"], \"cognate_protein\": \"HK022 Int\", \"core_overlap\": \"CAGTCACTATGAATCAACTACTTAGAT\", \"core_position\": \"203..230 (+ strand)\", \"recombinase_family\": \"tyrosine recombinase (lambda Int family)\"}",
      "cat:confidence": "high",
      "cat:reviewStatus": "ai-generated",
      "cat:sourceQuote": "The temperate bacteriophage HK022, like its relative lambda, inserts its chromosome into a specific site in the bacterial chromosome during lysogenization and excises it after induction.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:2547971"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:2547971"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:HK022_attP_claim_mechanism_provenance"
      },
      "rdfs:label": "Recombination substrate for the HK022 tyrosine (lambda-family) integrase; Int catalyzes site-specific strand exchange within the conserved overlap (O) core, flanked by arm-type and core-type Int-binding sites."
    },
    {
      "@id": "part:HK022_attP_claim_mechanism_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-workflow",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:HK022_attP_claim_orthogonality",
      "@type": "cat:FunctionalClaim",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"orthogonal_to\": [\"phiC31_attP\", \"186_attP\", \"phi80_attB\", \"lambda_attB\"], \"single_copy_integration\": true}",
      "cat:confidence": "medium",
      "cat:reviewStatus": "ai-generated",
      "cat:sourceQuote": "We describe \"clonetegration\", a method for integrating DNA into prokaryotic chromosomes ... clonetegration facilitates cloning and expression of genetic elements that are impossible to propagate within typical multicopy plasmids.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:24050148"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:24050148"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:HK022_attP_claim_orthogonality_provenance"
      },
      "rdfs:label": "Deployable in parallel with other phage att/Int systems (e.g. phiC31, 186, phi80) as an independent, orthogonal chromosomal landing pad, each recognized only by its cognate integrase."
    },
    {
      "@id": "part:HK022_attP_claim_orthogonality_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-workflow",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:HK022_attP_claim_specificity",
      "@type": "cat:FunctionalClaim",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"conserved_with_lambda\": \"arm-type Int-binding sites and overlap core\", \"cross_reactive_with_lambda\": false, \"specificity_determinant\": \"core-type Int-binding sites (B, B', C)\"}",
      "cat:confidence": "high",
      "cat:reviewStatus": "ai-generated",
      "cat:sourceQuote": "neither protein promotes efficient recombination between the pair of attachment sites used by the other phage ... allowed us to locate determinants of the specificity difference ... C, B, and most importantly, B'.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:2146253"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:2146253"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:HK022_attP_claim_specificity_provenance"
      },
      "rdfs:label": "HK022 and lambda att sites are NOT cross-reactive: each phage Int recombines only its cognate att pair. Specificity is determined by the core-type Int-binding sites (B, B', C), not the arm-type sites, which are conserved between the two phages."
    },
    {
      "@id": "part:HK022_attP_claim_specificity_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-workflow",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
