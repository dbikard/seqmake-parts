      "cat:analysisStatus": "pending",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"elution\": [\"imidazole\", \"low pH\"], \"matrices\": [\"NTA\", \"IDA\"], \"mechanism\": \"immobilized-metal affinity chromatography (IMAC)\", \"metal_ions\": [\"Ni2+\", \"Co2+\", \"Cu2+\", \"Zn2+\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "metal chelate adsorbent selective for proteins and peptides containing neighbouring histidine residues",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title/Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:3443622"
