      "@id": "part:rrnBT1_claim_phage_rnap_termination",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"hairpin_required\": false, \"polymerase\": \"T7/SP6\", \"sequence\": \"TATCTGTT\", \"signal\": \"class II conserved sequence\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "the conserved sequence TATCTGTT causes sequential conformational changes in T7 RNA polymerase, operating independently of the RNA hairpin",
      "cat:sourceQuoteFrom": "primary",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:15615852"
