      "cat:claimValue": "{\"advantage\": \"high sequence specificity (7-residue recognition) gives clean, minimal-scar tag removal\", \"founding_demonstration\": \"use of the TEV (ENLYFQ-S/G) site to release proteins/peptides from fusion proteins with a recombinant plant-virus proteinase\", \"function\": \"site_specific_protease_cleavage_site\", \"protease\": \"TEV protease\", \"use\": \"tag_removal_from_fusion_protein\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Release of proteins and peptides from fusion proteins using a recombinant plant virus proteinase",
      "cat:sourceQuoteFrom": "primary",
