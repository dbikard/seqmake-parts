    {
      "@id": "part:SpyTag003_claim_mechanism",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"catalytic_residue\": \"Glu77 of SpyCatcher003 (E77A abolishes reaction)\", \"mechanism\": \"intermolecular isopeptide (amide) bond formation on reconstitution of a split CnaB2-derived domain\", \"no_cysteine\": true, \"partner\": \"SpyCatcher003 (116 aa)\", \"partner_residue\": \"Lys31 of SpyCatcher003\", \"reactive_residue\": \"reactive Asp (CnaB2 Asp117) of SpyTag003\", \"reversibility\": \"irreversible; no detectable side reactions and no self-reactivity\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Amide bond formation between an amine and a carboxylic acid here occurs without any activating groups, and half-time for reaction is less than 30 s with 10 microM of each partner... Other important features of our reactive pair include the absence of Cys in either partner, lack of side reactions, and specificity in a range of cellular systems.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Discussion",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:SpyTag003_claim_mechanism_provenance"
      },
      "rdfs:label": "Spontaneous, irreversible isopeptide bond to SpyCatcher003 approaching the diffusion limit"
    },
    {
      "@id": "part:SpyTag003_claim_mechanism_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:SpyTag003_claim_origin",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "origin",
      "cat:claimValue": "{\"deposit\": \"QGX07220.1 protein / MN433888.1 nucleotide (Keeble & Howarth 2019)\", \"design\": \"library-based evolution + rational/computational design of the split CnaB2 (SpyTag/SpyCatcher) system through generations 001, 002, 003\", \"domain\": \"CnaB2 (immunoglobulin-like adhesin domain with spontaneous Lys-Asp isopeptide bond)\", \"organism\": \"Streptococcus pyogenes (ancestral domain)\", \"parent_protein\": \"fibronectin-binding protein FbaB\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The fibronectin binding protein, FbaB, from [S. pyogenes] contains a CnaB2 adhesin domain. CnaB2 is stabilized by a spontaneous reaction of Lys and Asp side chains to form an isopeptide bond... We previously achieved genetically encoded and covalent peptide-protein interaction by splitting CnaB2 into the 13-residue SpyTag peptide and the 116-residue SpyCatcher protein.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results - Engineering Toward Diffusion-Controlled Protein Coupling",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:SpyTag003_claim_origin_provenance"
      },
      "rdfs:label": "Engineered descendant of the S. pyogenes FbaB CnaB2 domain (Spy lineage)"
    },
    {
      "@id": "part:SpyTag003_claim_origin_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
