    {
      "@id": "part:CBP_tag_claim_application",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "application",
      "cat:claimValue": "{\"note\": \"That the TAP tag uses CBP as its second handle is stated in the body of Rigaut et al. 1999, not in its abstract (the abstract describes the TAP method without naming CBP); capped at medium pending primary full text.\", \"tag_architecture\": \"ProteinA-TEV-CBP (TAP); SBP-CBP (InterPlay)\", \"use\": \"tandem affinity purification of native protein complexes\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:sourceQuote": "We have developed a generic procedure to purify proteins expressed at their natural level under native conditions using a novel tandem affinity purification (TAP) tag.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:10504710"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:10504710"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:CBP_tag_claim_application_provenance"
      },
      "rdfs:label": "Second affinity handle of tandem-affinity purification (TAP / InterPlay) for protein-complex isolation"
    },
    {
      "@id": "part:CBP_tag_claim_application_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:CBP_tag_claim_binding_affinity",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "binding_affinity",
      "cat:claimValue": "{\"Kd_qualitative\": \"nanomolar\", \"Kd_wild_type_approx_nM\": 0.2, \"note\": \"Wild-type Kd ~0.2 nM is stated in the body of Mukherjee et al. 2015; the abstract only quotes the N5A variant Kd (~2 pM). The ~0.2 nM figure was not read in primary full text.\", \"partner\": \"calmodulin\"}",
      "cat:confidence": "low",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Calmodulin-binding peptide (CBP), a peptide of 26 amino acids derived from muscle myosin light chain kinase (MLCK), binds to calmodulin with nanomolar affinity.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9047344"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:9047344"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:CBP_tag_claim_binding_affinity_provenance"
      },
      "rdfs:label": "Binds calmodulin with nanomolar affinity (wild-type Kd ~0.2 nM)"
    },
    {
      "@id": "part:CBP_tag_claim_binding_affinity_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "primary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:CBP_tag_claim_expression_yield",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "expression_yield",
      "cat:claimValue": "{\"example_fusion\": \"CBP-JNK\", \"example_yield_mg_per_L\": \"15-20\", \"host\": \"Escherichia coli\", \"note\": \"Yield is for one example N-terminal CBP fusion; quoted from the abstract, not from an independently read figure/table.\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": false,
      "cat:sourceQuote": "the resulting fusion protein CBP-JNK synthesized in E. coli cells at 15-20 mg/1 culture. CBP-JNK was purified to near homogeneity in one step with calmodulin affinity resin.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9047344"
      },
      "prov:wasDerivedFrom": {
