      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "host_range",
      "cat:claimValue": "{\"context\": \"cell-surface labelling in 1 min on live mammalian cells; specific Western-blot detection with minimal cross-reactivity to endogenous proteins; intracellular split-protein (talin) reconstitution in mammalian cytoplasm\", \"validated_in\": [\"Escherichia coli\", \"human cells (Expi293, cell surface and cytoplasm)\", \"additional model-organism lysates by Western blot\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "We applied this reactive pair for specific labeling of a plasma membrane target in 1 min on live mammalian cells. Sensitive and specific detection was also confirmed by Western blot in a range of model organisms.",
