        }
      ]
    },
    {
      "@id": "part:186_attB",
      "@type": "sbol:Component",
      "cat:curationStatus": "candidate",
      "cat:documented": false,
      "cat:slug": "186_attB",
      "dcterms:description": "Phage 186 bacterial attachment site attB, overlapping the 3\u2032 half of the tRNA-Ile gene (preserved on integration). 46 bp shared core (identical to the 186_attP core), read 5\u2032->3\u2032 on the minus strand of NC_000913.3 at the tRNA-Ile locus. NCBI annotates the gene as ileX (b3069); the phage/pOSIP literature names the site ileY (distinct from NCBI ileY b2652 \u2014 a nomenclature caveat). Cognate phage site: 186_attP.",
