    {
      "@id": "collection:epitope-tags",
      "@type": "sbol:Collection",
      "dcterms:description": "Short linear peptide epitopes recognised by a well-characterised monoclonal antibody or nanobody, used to detect, localise, or immunoprecipitate a tagged protein without a native antibody. The collection includes the classical antibody epitopes HA, Myc, FLAG, T7, V5 and VSV-G, the bacteriophage-derived E-tag, and the modern high-affinity nanobody epitopes ALFA-tag, Spot-tag and BC2-tag, several of which support super-resolution imaging through small, single-domain binders with low linkage error. Detection is via the cognate antibody/nanobody; many double as affinity handles on an immobilised binder.",
      "dcterms:title": "Epitope / detection tags",
      "sbol:displayId": "epitope-tags",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
