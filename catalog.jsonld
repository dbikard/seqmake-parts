    {
      "@id": "part:HK022_attP",
      "@type": "sbol:Component",
      "cat:curationStatus": "candidate",
      "cat:documented": false,
      "cat:hasFunctionalClaim": [
        {
          "@id": "part:HK022_attP_claim_mechanism"
        },
        {
          "@id": "part:HK022_attP_claim_specificity"
        },
        {
          "@id": "part:HK022_attP_claim_host_range"
        },
        {
          "@id": "part:HK022_attP_claim_orthogonality"
        }
      ],
      "cat:slug": "HK022_attP",
      "dcterms:description": "HK022 phage attachment (att) site: the Int (tyrosine recombinase) recombination substrate that carries the arm-type and core-type Int-binding sites flanking the crossover overlap (O) region. Source-verified against X51962 (complement strand 229..486, 100% identity over 258 bp). The 27 bp O-region (overlap/core) lies at positions 203..230 on the plus strand and is conserved with the lambda att core. NOTE: although the catalog slug is 'attB', this exact sequence is the phage attP region of X51962 (annotated [242:469] on the plus strand of the deposit); the bacterial attB proper lies in the E. coli leuX tRNA-Leu gene. See recommendations.",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:2547971"
        },
        {
          "@id": "https://identifiers.org/pubmed:2146253"
        },
        {
          "@id": "https://identifiers.org/pubmed:11591683"
        },
        {
          "@id": "https://identifiers.org/pubmed:24050148"
        }
      ],
      "dcterms:title": "HK022_attB",
      "rdfs:label": "HK022_attB",
      "sbol:displayId": "HK022_attP",
      "sbol:hasNamespace": {
