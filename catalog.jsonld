    {
      "@id": "part:enterokinase_site",
      "@type": "sbol:Component",
      "cat:curationStatus": "validated",
      "cat:documented": true,
      "cat:hasFunctionalClaim": [
        {
          "@id": "part:enterokinase_site_claim_function"
        },
        {
          "@id": "part:enterokinase_site_claim_specificity"
        },
        {
          "@id": "part:enterokinase_site_claim_use_tag_removal"
        },
        {
          "@id": "part:enterokinase_site_claim_off_target_caveat"
        },
        {
          "@id": "part:enterokinase_site_claim_sequence_variant_DDDDR"
        }
      ],
      "cat:slug": "enterokinase_site",
      "dcterms:description": "Enterokinase (enteropeptidase) recognition/cleavage site (Asp-Asp-Asp-Asp-Lys). The protease cleaves on the C-terminal side of the Lys (after K), releasing a downstream protein with no residual vector-derived residues \u2014 hence its wide use for tag removal from fusion proteins. The acidic (Asp)4 tetrad and the P1 Lys are recognized by the enterokinase light-chain S1\u2013S5 basic substrate pocket. Sequence DDDDK is a 100%-identity match to residues 19\u201323 of the trypsinogen-1 activation propeptide (UniProt:P00760), the canonical natural occurrence of the motif. This part covers a 5-aa sub-span of that 247-aa precursor (full_length_match=false), which is expected for a short recognition motif and is not a sequence defect.",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:5570436"
        },
        {
          "@id": "https://identifiers.org/pubmed:2658218"
        },
        {
          "@id": "https://identifiers.org/pubmed:8226855"
        },
        {
          "@id": "https://identifiers.org/pubmed:9636275"
        },
        {
          "@id": "https://identifiers.org/pubmed:9395456"
        },
        {
          "@id": "https://identifiers.org/pubmed:16672368"
        },
        {
          "@id": "https://identifiers.org/pubmed:17097793"
        },
        {
          "@id": "https://identifiers.org/pubmed:21515380"
        },
        {
          "@id": "https://identifiers.org/pubmed:23436726"
        },
        {
          "@id": "https://identifiers.org/pubmed:36376282"
        },
        {
          "@id": "https://identifiers.org/pubmed:11745150"
        }
      ],
      "dcterms:title": "enterokinase_site",
      "rdfs:label": "enterokinase_site",
      "sbol:displayId": "enterokinase_site",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
      "sbol:hasSequence": {
