      "prov:wasGeneratedBy": {
        "@id": "part:SNAP_tag_claim_application_provenance"
      },
      "rdfs:label": "SNAP-tag enables specific covalent labeling of fusion proteins with synthetic small-molecule probes (e.g. fluorophores) in living cells, for imaging and protein-function studies"
    },
