    {
      "@id": "part:SNAP_tag_claim_application",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "application",
      "cat:claimValue": "{\"applications\": [\"live-cell protein labeling\", \"fluorescence imaging\", \"pulse-chase tracking of protein generations\"], \"modularity\": \"a single genetic fusion can be decorated with diverse probes by changing the molecule appended to the BG substrate\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Here we describe a general method for the covalent labeling of fusion proteins in vivo that complements existing methods for noncovalent labeling of proteins and that may open up new ways of studying proteins in living cells.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
