    },
    {
      "@id": "part:CBP_tag_claim_post_translational",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "post_translational",
      "cat:claimValue": "{\"enzyme\": \"cAMP-dependent protein kinase (PKA)\", \"use\": \"direct labeling with [gamma-32P]ATP\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "We also show that CBP can be efficiently phosphorylated by cAMP-dependent protein kinase. Hence, the purified fusion proteins can be labeled directly with [gamma-32P]ATP and used to probe protein-protein or protein-nucleic acid interactions.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
