    {
      "@id": "part:Pxyl_tet",
      "@type": "sbol:Component",
      "cat:curationStatus": "validated",
      "cat:documented": true,
      "cat:hasFunctionalClaim": {
        "@id": "part:Pxyl_tet_claim_regulation"
      },
      "cat:slug": "Pxyl_tet",
      "cat:sourceAccession": "GenBank:JN635500.1",
      "dcterms:description": "Pxyl/tet: the TetR-repressible / anhydrotetracycline (aTc)-inducible promoter of the Staphylococcus aureus pRAB expression vectors (Helle et al. 2011). A consensus sigma-70/sigma-A -35 (TTGACA) / -10 (TATAAT) promoter carrying two Tn10 tet operators (the O2/O1 tandem) - one in the -35/-10 spacer and one downstream of the -10 - so bound TetR occludes RNA polymerase until aTc relieves repression. Sequence of record: pRAB11 (GenBank JN635500.1).",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:21921101"
        },
