      "cat:slug": "BC2_tag",
      "dcterms:description": "12-aa linear epitope tag PDRKAAVSHWQQ (BC2T), corresponding to residues 16\u201327 of human beta-catenin (UniProt P35222). Bound by the BC2 nanobody (BC2-Nb) with Kd ~1.4 nM via a 'headlock' binding mode: the peptide adopts a beta-strand that integrates into a beta-sheet of the nanobody, providing affinity through backbone hydrogen bonds. Specificity is set by only four side chains (R3, A6, S8, W10, with W10 invariable); the other eight positions tolerate substitution, allowing the tag to be re-engineered. Functions as a single binding epitope with no independently used internal sub-elements.",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:26791954"
        },
        {
          "@id": "https://identifiers.org/pubmed:29500346"
        },
        {
          "@id": "https://identifiers.org/pubmed:25595278"
        },
        {
          "@id": "https://identifiers.org/pubmed:35780707"
        }
      ],
      "dcterms:title": "BC2_tag",
      "rdfs:label": "BC2_tag",
      "sbol:displayId": "BC2_tag",
      "sbol:hasNamespace": {
        "@id": "https://w3id.org/seqmake/parts/"
      },
