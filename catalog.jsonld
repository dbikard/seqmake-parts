    {
      "@id": "part:LPETG_tag",
      "@type": "sbol:Component",
      "cat:curationStatus": "validated",
      "cat:documented": true,
      "cat:hasFunctionalClaim": [
        {
          "@id": "part:LPETG_tag_claim_recognition_specificity"
        },
        {
          "@id": "part:LPETG_tag_claim_mechanism"
        },
        {
          "@id": "part:LPETG_tag_claim_natural_origin"
        },
        {
          "@id": "part:LPETG_tag_claim_application"
        },
        {
          "@id": "part:LPETG_tag_claim_placement"
        },
        {
          "@id": "part:LPETG_tag_claim_host_range"
        },
        {
          "@id": "part:LPETG_tag_claim_sequence_variant"
        },
        {
          "@id": "part:LPETG_tag_claim_natural_origin__v2"
        }
      ],
      "cat:slug": "LPETG_tag",
      "dcterms:description": "Sortase A (SrtA) recognition motif and a single instance of the Gram-positive LPXTG cell-wall sorting signal (Leu-Pro-Glu-Thr-Gly). SrtA cleaves the scissile peptide bond between the P1 Thr and the P1' Gly (LPET|G), forming a covalent acyl-enzyme thioester intermediate at the active-site Cys; this intermediate is resolved by nucleophilic attack of an N-terminal oligoglycine (Gly-n, typically GGG/GGGGG) acceptor, ligating the upstream protein to the acceptor and regenerating an LPETGG... junction. Whole-part feature spanning all 5 residues; this is a single atomic functional element with no functional sub-features. The X position of the LPXTG consensus is most commonly Glu (E) in efficient engineering substrates. Source-verified to UniProt P02976 (Protein A) Motif 'LPXTG sorting signal' at positions 482-486, 5/5 identity.",
      "dcterms:references": [
        {
          "@id": "https://identifiers.org/pubmed:10427003"
        },
        {
          "@id": "https://identifiers.org/pubmed:10535938"
        },
        {
          "@id": "https://identifiers.org/pubmed:14995162"
        },
        {
          "@id": "https://identifiers.org/pubmed:23989673"
        },
        {
          "@id": "https://identifiers.org/pubmed:21697512"
        },
        {
          "@id": "https://doi.org/10.1073/pnas.1411179111"
        },
        {
          "@id": "https://identifiers.org/pubmed:24586638"
        },
        {
          "@id": "https://identifiers.org/pubmed:25644005"
        }
      ],
      "dcterms:title": "LPETG_tag",
