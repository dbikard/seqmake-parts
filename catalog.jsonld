    {
      "@id": "part:E-tag",
      "@type": "sbol:Component",
      "cat:curationStatus": "validated",
      "cat:documented": true,
      "cat:hasFunctionalClaim": [
        {
          "@id": "part:E-tag_claim_epitope_detection"
        },
        {
          "@id": "part:E-tag_claim_epitope_origin"
        },
        {
          "@id": "part:E-tag_claim_scfv_linker_stability"
        },
        {
          "@id": "part:E-tag_claim_anti_e_tag_antibody_cost_limitation"
        }
      ],
      "cat:slug": "E-tag",
      "dcterms:description": "Synthetic 13-residue epitope/affinity tag GAPVPYPDPLEPR derived from M13 bacteriophage g3p (gene III protein). It is the C-terminal detection/purification tag of the pCANTAB 5E phage-display vector (Pharmacia/GE), used to track and purify scFv-g3p fusion proteins and free scFv/Fab fragments via anti-E-tag monoclonal antibody. Conceptually based on the g3p-peptide epitope recognized by mAb 10C3 (Beckmann et al., 1998). Note: this string is also coincidentally present in human osteocalcin (UniProt P02818); that match is unrelated to the engineered tag's origin.",
