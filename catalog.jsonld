      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:SpyTag003_claim_application",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "application",
      "cat:claimValue": "{\"applications\": [\"rapid, sensitive detection (flow cytometry, Western blot)\", \"fast cell-surface labelling on live cells\", \"intracellular split-protein reconstitution (e.g. talin)\", \"irreversible anchoring on beads / biomaterials\", \"oligomerisation and plug-and-display vaccine scaffolds\", \"Spy&Go affinity purification of SpyTag003 fusions\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "This work also supports the use of SpyTag003 to enhance the range of applications of a fused protein. Proteins linked to SpyTag and its variants are empowered for Spy&Go affinity purification, irreversible anchoring (on magnetic beads or biomaterials), or oligomerization (on coiled-coils or vaccine scaffolds).",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Discussion",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:31822621"
      },
      "prov:wasDerivedFrom": {
