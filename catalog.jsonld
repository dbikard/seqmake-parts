      },
      "prov:wasGeneratedBy": {
        "@id": "part:Trx_tag_claim_redox_active_site_provenance"
      },
      "rdfs:label": "The WCGPCK active site (residues 32\u201337) contains the Cys33/Cys36 redox-active disulfide; this site enables Trx to reduce protein disulfide bonds as part of the thioredoxin/thioredoxin-reductase electron-relay system."
    },
