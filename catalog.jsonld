      "prov:wasGeneratedBy": {
        "@id": "part:SpyTag003_claim_binding_affinity_provenance"
      },
      "rdfs:label": "Covalent (effectively infinite affinity); non-reactive SpyTag003 DA binds SpyCatcher003 with Kd ~21 nM"
    },
    {
