    {
      "@id": "part:186_attP_claim_mechanism",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"directionality_factor\": \"Apl\", \"host_factor\": \"IHF\", \"reaction\": \"attP x attB -> attL + attR\", \"recombinase\": \"186 Int\", \"recombinase_family\": \"tyrosine integrase (lambda integrase family)\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "the site-specific recombination proteins encoded by bacteriophage lambda, phi 80, P22, P2, 186, P4 and P1 ... Three positions are perfectly conserved within this family: histidine, arginine and tyrosine ... tyrosine-433 forms a transient covalent linkage to DNA during strand cleavage and rejoining.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:3011407"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:3011407"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:186_attP_claim_mechanism_provenance"
      },
      "rdfs:label": "186 attP is the phage attachment site for 186 tyrosine (lambda-family) integrase-mediated site-specific recombination; integrative recombination (attP x attB -> attL/attR) requires 186 Int plus host IHF."
    },
