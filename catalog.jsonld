      "cat:claimValue": "{\"condition\": \"with a twofold excess of SnoopCatcher, SnoopTag-MBP reacted quantitatively; with excess SnoopTag-MBP, SnoopCatcher was ~100% consumed\", \"readout\": \"isopeptide bond (SDS-stable complex) by SDS-PAGE\", \"yield\": \">99%\"}",
      "cat:confidence": "high",
