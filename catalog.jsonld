      "cat:analysisStatus": "pending",
      "cat:claimType": "orthogonality",
      "cat:claimValue": "{\"clip_substrate\": \"O2-benzylcytosine derivatives\", \"orthogonal_partner\": \"CLIP-tag\", \"snap_substrate\": \"O6-benzylguanine derivatives\", \"use\": \"simultaneous two-color labeling of two distinct fusion proteins in living cells\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "Because SNAP-tag and CLIP-tag possess orthogonal substrate specificities, SNAP and CLIP fusion proteins can be labeled simultaneously and specifically with different molecular probes in living cells.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "abstract",
      "dcterms:references": {
