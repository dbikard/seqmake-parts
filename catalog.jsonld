      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"active_site_motif\": \"WCGPCK\", \"active_site_residues_1based\": \"32\\u201337\", \"catalytic_cysteines\": [\"Cys33\", \"Cys36\"], \"cognate_reductant\": \"TrxB (thioredoxin reductase)\", \"reaction\": \"dithiol-disulfide exchange\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceQuote": "The CXXC motif: crystal structure of an active-site variant of Escherichia coli thioredoxin",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title/Results",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:10489448"
