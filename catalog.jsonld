    {
      "@id": "part:AviTag",
      "@type": "sbol:Component",
      "cat:curationStatus": "validated",
      "cat:documented": true,
      "cat:hasFunctionalClaim": [
        {
          "@id": "part:AviTag_claim_mechanism"
        },
        {
          "@id": "part:AviTag_claim_origin"
        },
