    },
    {
      "@id": "part:SnoopCatcher_claim_conditions",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "pending",
      "cat:claimType": "conditions",
      "cat:claimValue": "{\"buffer\": \"no specific component required; works in PBS, with Triton X-100/Tween-20, or 1 M NaCl; modestly enhanced by 1.5 M TMAO\", \"pH_range\": \"6-9\", \"redox\": \"insensitive to DTT (no cysteine in SnoopTag/SnoopCatcher)\", \"temperature_range_C\": \"4-37\"}",
      "cat:confidence": "high",
      "cat:crossChecked": false,
      "cat:sourceFigure": "Fig 2A,B",
      "cat:sourceQuote": "We established that reaction proceeded efficiently from pH 6-9 (Fig 2A) and 4-37 C (Fig 2B). Cysteine is absent from SnoopTag and SnoopCatcher, so, as expected, the reaction was insensitive to DTT ... No specific buffer component was required",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Results",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:26787909"
