    {
      "@id": "part:AviTag_claim_caveat",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "caveat",
      "cat:claimValue": "{\"failure_modes\": [\"incomplete in vivo biotinylation (50-80%), leaving unbiotinylated target that co-purifies\", \"BirA may biotinylate accessible endogenous lysines if overexpressed or if the tag is in a crowded environment\", \"high intracellular biotin supplementation required for efficient in vivo labeling\", \"tag must be surface-exposed for live-cell BirA-mediated labeling\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "The efficiency of enzymatic biotinylation with BirA varies between 50\u201380% in vivo, or 80\u2013100% in vitro [20]. Optimizing the reaction conditions or strategically placing the AviTag at different ends of the protein has been shown to improve the efficiency, but complete biotinylation is almost impossible to achieve.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title/Abstract",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Describes a quantitative limitation and failure mode (incomplete biotinylation with specific efficiency range) that directly affects how the tag performs in practice. Actionable for designers choosing between in vivo vs in vitro biotinylation strategies. High risk-reduction value.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:38662935"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:38662935"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_caveat_provenance"
      },
      "rdfs:label": "In vivo biotinylation is incomplete (typically 50-80%); unbiotinylated fraction co-purifies and can be problematic for quantitative applications; AviTrap or in vitro biotinylation are workarounds."
    },
    {
      "@id": "part:AviTag_claim_caveat_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:AviTag_claim_expression_yield",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "expression_yield",
      "cat:claimValue": "{\"in_vitro_efficiency_pct\": \"80-100\", \"in_vivo_efficiency_pct\": \"50-80\", \"limiting_factors\": [\"BirA concentration\", \"intracellular biotin availability\", \"tag accessibility\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "The efficiency of enzymatic biotinylation with BirA varies between 50\u201380% in vivo, or 80\u2013100% in vitro",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Fills a critical operational datasheet slot for protein_tag selection: quantifies the biotinylation efficiency achievable by two standard modes (in vitro vs in vivo), which directly guides engineers' choice of method and planning for downstream applications (purification yield, quantitative requirements)",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:38662671"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:38662671"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_expression_yield_provenance"
      },
      "rdfs:label": "In vitro biotinylation with purified BirA achieves 80-100% biotinylation efficiency; in vivo efficiency is typically 50-80% and depends on BirA:substrate ratio and biotin availability."
    },
    {
      "@id": "part:AviTag_claim_expression_yield_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:AviTag_claim_host_range",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "sources-pending",
      "cat:claimType": "host_range",
      "cat:claimValue": "{\"notes\": \"BirA must be co-expressed or added exogenously; endogenous mammalian biotin ligases do not efficiently biotinylate the peptide\", \"validated_in\": [\"Escherichia coli (in vivo, co-expression of BirA)\", \"Spodoptera frugiperda insect cells (in vivo, baculovirus BirA co-expression; PMID:9750126)\", \"mammalian cell surface (extracellular BirA application; PMID:15897449)\", \"cell-free in vitro (purified BirA; PMID:25560075)\"]}",
      "cat:confidence": "low",
      "cat:crossChecked": false,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "Site-specific, enzymatic biotinylation of recombinant proteins in Spodoptera frugiperda cells using biotin acceptor peptides",
      "cat:sourceQuoteFrom": "catalog-doc",
      "cat:sourceSection": "Title",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Host range is a core datasheet_slot for protein tags \u2014 directly informs designer choice of expression system and deployment conditions. Knowing which organisms/contexts support biotinylation is operationally critical.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:9750126"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:9750126"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_host_range_provenance"
      },
      "rdfs:comment": "PMID 9750126 is solely about Spodoptera frugiperda insect cells; it does not demonstrate biotinylation in bacteria, mammalian cells, or in vitro systems. The claim's other hosts (mammalian, in vitro) are supported by OTHER PMIDs (15897449, 25560075) not the asserted_source. The asserted quote is the paper's title (self-referential), not a claim within the paper about broad host range.",
      "rdfs:label": "AviTag is biotinylated by E. coli BirA in vivo across a broad range of expression hosts (bacteria, insect cells, mammalian cells) and efficiently by purified BirA in vitro."
    },
    {
      "@id": "part:AviTag_claim_host_range_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:AviTag_claim_mechanism",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "mechanism",
      "cat:claimValue": "{\"biotinylated_residue\": \"Lys11 (K10 in original Schatz 1993 numbering)\", \"enzyme\": \"BirA (biotin holoenzyme synthetase)\", \"mechanism\": \"ATP-dependent enzymatic biotinylation; biotin transferred from biotin-AMP intermediate to epsilon-amine of lysine\", \"specificity\": \"single-site, sequence-specific; BirA does not biotinylate other cellular lysines under standard conditions\"}",
      "cat:confidence": "high",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "In the first step, the enzyme catalyzes formation of an activated intermediate, biotinyl-59-adenylate (bio-59-AMP) from biotin and ATP. Subsequent nucleophilic attack at the activated carboxylate of biotin results in formation of the amide between the biotin moiety and the target lysine residue.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title/Abstract",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Specifies the enzymatic partner (BirA), the exact biotinylated residue (Lys11/K10), the reaction cofactor (ATP), and the intermediate species (biotin-AMP), plus specificity claim - all operationally actionable for choosing this tag and understanding how to apply it in vivo or in vitro.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:10211839"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:10211839"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_mechanism_provenance"
      },
      "rdfs:label": "AviTag is site-specifically biotinylated on Lys11 by BirA biotin ligase; the reaction is ATP-dependent and the product biotin-lysine (biotinyl-AMP intermediate) is covalently attached."
    },
    {
      "@id": "part:AviTag_claim_mechanism_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:AviTag_claim_origin",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "origin",
      "cat:claimValue": "{\"design\": \"in vitro peptide library screening followed by kinetic optimization to 15-mer\", \"organism_source\": \"fully synthetic; no natural protein parent\", \"original_name\": \"Biotin Acceptor Peptide (BAP); 'AviTag' is a commercial synonym\", \"parent\": \"13-aa BirA consensus peptide (Schatz 1993)\"}",
      "cat:confidence": "medium",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "Selection of the modified peptides on this binding protein produced an extensive family of biotinylation substrate peptides that define a consensus sequence spanning a region of 13 amino acids.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Title",
      "cat:usefulness": "low",
      "cat:usefulnessRationale": "Historical/bibliographic claim restating provenance. Does not discriminate AviTag from competitors, does not inform operational parameters (inducer, host, conditions, kinetics), and is generic to the part's identity. Useful primarily for citations rather than choice/operation.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:7764094"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:7764094"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_origin_provenance"
      },
      "rdfs:label": "AviTag is a fully synthetic 15-mer derived by combinatorial optimization from a 13-residue BirA consensus first identified by Schatz 1993 using peptide-library screening."
    },
    {
      "@id": "part:AviTag_claim_origin_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:AviTag_claim_placement",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "placement",
      "cat:claimValue": "{\"accessibility_requirement\": \"BirA requires access to the lysine side-chain; buried or sterically occluded tags are poorly biotinylated\", \"linker_recommended\": true, \"positions\": [\"N-terminal\", \"C-terminal\", \"internal loop\"]}",
      "cat:confidence": "high",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "AviTag can conveniently be added genetically at the N-terminus, C-terminus, or in exposed loops of a target protein ... We would suggest including a flexible two residue GS linker between the AviTag and the target protein ... For Dicer, Lau et al. describe several functional and some nonfunctional peptide insertion sites, advising insertion in short loops disordered in the crystal structure or less highly conserved.",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract/Methods",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Placement constraints are directly operationally actionable: a designer must decide where (N, C, or internal loop) to insert AviTag in their fusion construct; accessibility/surface exposure requirement is a risk-reducing caveat; linker recommendation is a specific parameter to optimize yield.",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:25560075"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:25560075"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_placement_provenance"
      },
      "rdfs:label": "AviTag can be fused at the N-terminus, C-terminus, or as an internal loop insertion; accessibility to BirA is required and surface exposure is critical for efficient in vivo biotinylation."
    },
    {
      "@id": "part:AviTag_claim_placement_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
    {
      "@id": "part:AviTag_claim_sequence_variant",
      "@type": "cat:FunctionalClaim",
      "cat:analysisStatus": "verified",
      "cat:claimType": "sequence_variant",
      "cat:claimValue": "{\"canonical_15mer\": \"GLNDIFEAQKIEWHE\", \"note\": \"Slow variants designed to report only on close-proximity BirA-fused proteins\", \"precursor_13mer\": \"Schatz 1993 consensus (PMID:7764094)\", \"slow_variants\": [{\"application\": \"PUB proximity assay\", \"name\": \"BAP1070\", \"relative_rate\": \"~1/45 of AviTag\"}, {\"application\": \"PUB proximity assay\", \"name\": \"BAP1108\", \"relative_rate\": \"~1/48 of AviTag\"}]}",
      "cat:confidence": "high",
      "cat:crossChecked": true,
      "cat:lastChecked": {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      },
      "cat:sourceQuote": "The time of half-saturation was 45 (BAP1070) and 48 times (BAP1108) greater in comparison with parallel cotransfections of BirA-GFP and AviTag-GFP (680 and 720 min vs. 15 min).",
      "cat:sourceQuoteFrom": "primary",
      "cat:sourceSection": "Abstract",
      "cat:usefulness": "high",
      "cat:usefulnessRationale": "Provides quantitative kinetic comparison (45-48x fold difference) and application context (PUB proximity assays), directly relevant for designers choosing between AviTag and slower variants for proximity-based detection",
      "dcterms:references": {
        "@id": "https://identifiers.org/pubmed:35207587"
      },
      "prov:wasDerivedFrom": {
        "@id": "https://identifiers.org/pubmed:35207587"
      },
      "prov:wasGeneratedBy": {
        "@id": "part:AviTag_claim_sequence_variant_provenance"
      },
      "rdfs:label": "Slow-kinetics variants BAP1070 and BAP1108 (45-48x slower than AviTag) enable proximity-based PUB assays; the original 13-mer consensus (Schatz 1993) is a less-efficient precursor."
    },
    {
      "@id": "part:AviTag_claim_sequence_variant_provenance",
      "@type": "prov:Activity",
      "cat:agent": "annotate-part-engine",
      "cat:fromDoc": "secondary",
      "cat:method": "ai-extraction"
    },
