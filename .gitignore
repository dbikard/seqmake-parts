# Generated website (rebuilt by tools/build_catalog.py + CI)
/docs/index.md
/docs/parts_index.json
/docs/parts/
/docs/types/
/docs/collections/
/docs/tags.md
/site/

.env

# Source-document handoff: human-provided PDFs/sequences staged for the agent
# (kept local — only the resulting part record + its provenance citation are committed)
/sourcing/incoming/

# Local full-text paper store (tools/papers.py) — paywalled PDFs + extracted text +
# index, keyed by PMID/DOI for the cross-check/verifier agents. A personal reference
# cache; copyrighted full text is never committed.
/sourcing/papers/

# Local sequence-provenance store (tools/sequences.py) — NON-publicly-refetchable
# carrier maps (commercial/unpublished plasmids, e.g. pDONR221) keyed by name/accession,
# so the add-part Source phase can byte-verify a part against them. Only the resulting
# provenance.sequence_source string is committed; the carriers themselves stay local.
/sourcing/sequences/

# Python
__pycache__/
*.pyc
.venv/

# Claude Code local (personal) settings
.claude/settings.local.json
