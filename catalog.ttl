part:Pxyl_tet_claim_regulation a cat:FunctionalClaim ;
    rdfs:label "TetR-repressible / anhydrotetracycline (aTc)-inducible (S. aureus pRAB)." ;
    dcterms:references pubmed:21921101 ;
    prov:wasDerivedFrom pubmed:21921101 ;
    prov:wasGeneratedBy part:Pxyl_tet_claim_regulation_provenance ;
    cat:claimType "regulation" ;
    cat:claimValue "{\"inducer\": \"anhydrotetracycline (aTc)\", \"regulation\": \"inducible\", \"repressor\": \"TetR\"}" ;
    cat:confidence "high" ;
    cat:inducer "anhydrotetracycline (aTc)" ;
    cat:regulation "inducible" ;
    cat:reviewStatus "ai-generated" ;
    cat:sourceQuote "Pxyl/tet: the TetR-repressible / anhydrotetracycline (aTc)-inducible promoter of the Staphylococcus aureus pRAB expression vectors (Helle et al. 2011). A consensus sigma-70/sigma-A -35 (TTGACA) / -10 (TATAAT) promoter carrying two Tn10 tet operators (the O2/O1 tandem) - one in the -35/-10 spacer and one downstream of the -10 - so bound TetR occludes RNA polymerase until aTc relieves repression. Sequence of record: pRAB11 (GenBank JN635500.1)." ;
    cat:sourceQuoteFrom "catalog-doc" .

