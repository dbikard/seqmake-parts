    cat:claimValue "{\"differences_bp\": 2, \"earliest_deposit\": \"X01803 (1985)\", \"interpretation\": \"benign (ubiquitous in widely-used vectors)\", \"n_carriers_pre1997\": 142, \"positions\": \"412-413\", \"vs_canonical\": \"ColE1 (pBR322 J01749 / pUC18 L08752)\"}" ;
    cat:confidence "high" ;
    cat:reviewStatus "ai-generated" ;
    cat:sourceQuote "100% identity to GenBank X03174 (cloning vector pEX2, 1986) and 142 pre-1997 deposited vectors; earliest X01803 (Nov 1985)" ;
