part:rop_claim_copy_number a cat:FunctionalClaim ;
    rdfs:label "Rop is a trans-acting repressor of the RNA primer promoter (its name = 'repressor of primer'), negatively regulating ColE1/pMB1 plasmid copy number." ;
    dcterms:references pubmed:6183660 ;
    prov:wasDerivedFrom pubmed:6183660 ;
    prov:wasGeneratedBy part:rop_claim_copy_number_provenance ;
    cat:claimType "copy_number" ;
    cat:claimValue "{\"cognate_origin\": \"ColE1/pMB1 (RNA I / RNA II)\", \"effect_on_copy_number\": \"lowers\", \"role\": \"negative regulator\"}" ;
    cat:confidence "high" ;
    cat:reviewStatus "ai-generated" ;
    cat:sourceQuote "Transcription from the RNA primer promoter, however, is repressed by the product of a trans-acting plasmid gene product, which we have designated rop (for repressor of primer)." ;
    cat:sourceQuoteFrom "primary" .

